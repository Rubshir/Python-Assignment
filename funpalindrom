#9 use a function to check palindrom number

def pelindrom(n,rev):
  while(n>0):
    r = n%10
    rev = rev * 10 + r
    n= int(n/10)
  return rev

n = int(input("Enter a number : "))
rev = 0

pel = pelindrom(n,rev)

if(pel == n):
  print(n,"is a pelindrom number")
else:
  print(n,"is not a pelindrom number")